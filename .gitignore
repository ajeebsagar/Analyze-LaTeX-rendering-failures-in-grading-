# ==========================================================================
# Large dataset files (master raw + classified). Exceed GitHub's 100MB limit.
# These should be stored in S3 / Google Drive / tenant DB, not in git.
# ==========================================================================
classified_candidates.jsonl
all_candidates.jsonl
*.tar.gz

# ==========================================================================
# Pipeline output — regeneratable by running the CLI. Some are >100MB.
# ==========================================================================
renderer/out/
renderer/out_solid/
renderer/web/inspector/data.json
renderer/web/inspector/_synth*.json*

# Per-row trace outputs (always huge, always regeneratable)
**/results.jsonl
**/fallback_rows.jsonl

# Synthetic + scratch outputs
renderer/_synth_dataset.jsonl
renderer/_synth_failures.jsonl
renderer/_probe_out.txt
renderer/_probe_full_out.txt
renderer/_probe_fields_out.txt
renderer/_analysis_rare.txt

